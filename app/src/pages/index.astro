---
import BaseLayout from '@layouts/BaseLayout.astro';
import { business, services, serviceUrl } from '@data/business';
import {
  Phone,
  MessageCircle,
  Award,
  Clock,
  MapPin,
  Car,
  Wrench,
  ShoppingCart,
  Scale,
  ShieldCheck,
  Gavel,
} from 'lucide-react';
import ContactForm from '@components/forms/ContactForm.tsx';
import HeroReviews from '@components/hero/HeroReviews.tsx';
import { getCollection } from 'astro:content';
import { geoMercator, geoPath } from 'd3-geo';
import voivodeshipsData from '@data/poland-voivodeships.json';
import type { FeatureCollection, Feature, Geometry } from 'geojson';

type VoivodeshipProps = { nazwa: string };
const voivodeships = voivodeshipsData as FeatureCollection<Geometry, VoivodeshipProps>;
const MAP_W = 1064;
const MAP_H = 1000;
const polandProjection = geoMercator().fitSize([MAP_W, MAP_H], voivodeships);
const polandPathGen = geoPath(polandProjection);
const trimSvgPath = (d: string) => d.replace(/-?\d+(?:\.\d+)?/g, (n) => Math.round(parseFloat(n)).toString());
const round1 = (n: number) => Math.round(n * 10) / 10;
const renderedVoivodeships = voivodeships.features.map((feature) => {
  const [cx, cy] = polandPathGen.centroid(feature as Feature<Geometry>);
  const labelX = round1(cx);
  const labelY = round1(cy);
  return {
    key: feature.properties.nazwa,
    name: feature.properties.nazwa,
    path: trimSvgPath(polandPathGen(feature as Feature<Geometry>) ?? ''),
    labelX,
    labelY,
    tooltipX: labelX,
    tooltipY: labelY,
  };
});
type CityTier = 'major' | 'small';
type LabelAlign = 'start' | 'end' | 'middle';
interface CityInput {
  name: string;
  lon: number;
  lat: number;
  tier: CityTier;
  capital?: boolean;
  align?: LabelAlign;
  dx?: number;
  dy?: number;
  showLabel?: boolean;
}
const cityList: CityInput[] = [
  { name: 'Warszawa', lon: 21.0122, lat: 52.2297, tier: 'major', capital: true, align: 'start', dy: -10 },
  { name: 'Poznań',   lon: 16.9252, lat: 52.4064, tier: 'major', align: 'end',   dx: -16, dy: -14 },
  { name: 'Kraków',   lon: 19.9450, lat: 50.0647, tier: 'major', align: 'start', dy: -10 },
  { name: 'Gdańsk',   lon: 18.6466, lat: 54.3520, tier: 'major', align: 'middle', dy: -14 },
  { name: 'Łódź',     lon: 19.4560, lat: 51.7592, tier: 'major', align: 'start', dy: 22 },
  { name: 'Bydgoszcz',lon: 18.0084, lat: 53.1235, tier: 'major', align: 'start', dy: -10 },
  { name: 'Kalisz',   lon: 18.0911, lat: 51.7611, tier: 'major', align: 'start', dx: 18, dy: -12 },
  { name: 'Ostrów Wlkp.',       lon: 17.81,   lat: 51.65,   tier: 'small', align: 'start', dx: 18, dy: -12 },
  { name: 'Odolanów',           lon: 17.6750, lat: 51.5667, tier: 'small', align: 'end',   dx: -20, dy: 22 },
  { name: 'Ostrzeszów',         lon: 17.9311, lat: 51.4275, tier: 'small', align: 'start', dx: 20, dy: 6 },
  { name: 'Kępno',              lon: 17.9833, lat: 51.2833, tier: 'small', align: 'start', dx: 18, dy: 22 },
  { name: 'Jarocin',            lon: 17.5000, lat: 51.9667, tier: 'small', align: 'end',   dx: -18, dy: -12 },
  { name: 'Krotoszyn',          lon: 17.4333, lat: 51.7000, tier: 'small', align: 'end',   dx: -22, dy: 8 },
  { name: 'Pleszew',            lon: 17.7878, lat: 51.8961, tier: 'small', align: 'start', dx: 18, dy: -4 },
  { name: 'Grabów nad Prosną',  lon: 18.0833, lat: 51.5000, tier: 'small', align: 'start', dy: 5, showLabel: false },
  { name: 'Środa Wlkp.',        lon: 17.2789, lat: 52.2261, tier: 'small', align: 'end',   dy: 5, showLabel: false },
  { name: 'Milicz',             lon: 17.2833, lat: 51.5333, tier: 'small', align: 'end',   dx: -18, dy: 24 },
  { name: 'Twardogóra',         lon: 17.4667, lat: 51.3667, tier: 'small', align: 'end',   dy: 5, showLabel: false },
  { name: 'Oleśnica',           lon: 17.3833, lat: 51.2167, tier: 'small', align: 'end',   dx: -20, dy: 18 },
  { name: 'Syców',              lon: 17.7167, lat: 51.3000, tier: 'small', align: 'start', dx: 18, dy: -8 },
  { name: 'Trzebnica',          lon: 17.0628, lat: 51.3122, tier: 'small', align: 'end',   dy: 5, showLabel: false },
  { name: 'Długołęka',          lon: 17.1833, lat: 51.1833, tier: 'small', align: 'end',   dy: -8, showLabel: false },
];
const cityMarkers = cityList.map((c) => {
  const [x, y] = polandProjection([c.lon, c.lat]) ?? [0, 0];
  const labelOffsetX = c.dx ?? (c.align === 'end' ? -8 : c.align === 'start' ? 8 : 0);
  return {
    ...c,
    x: round1(x),
    y: round1(y),
    labelX: round1(x + labelOffsetX),
    labelY: round1(y + (c.dy ?? 5)),
  };
});
const brandPins = [
  { name: business.address.city, sub: 'siedziba', lon: business.geo.longitude, lat: business.geo.latitude, primary: true },
  { name: 'Wrocław',      sub: null,       lon: 17.0385, lat: 51.1079, primary: false },
].map((p) => {
  const [x, y] = polandProjection([p.lon, p.lat]) ?? [0, 0];
  return { ...p, x: round1(x), y: round1(y), xPct: round1((x / MAP_W) * 100), yPct: round1((y / MAP_H) * 100) };
});

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

const allOpinions = await getCollection('opinions');
const previewUnverifiedOpinions = import.meta.env.DEV;
const heroReviews = allOpinions
  .filter((o) => o.data.verified === true || previewUnverifiedOpinions)
  .map((o) => o.data)
  .sort(
    (a, b) =>
      Number(b.verified) - Number(a.verified) ||
      b.rating - a.rating ||
      (b.publishedAt?.getTime() ?? 0) - (a.publishedAt?.getTime() ?? 0)
  )
  .slice(0, 5)
  .map((o) => ({
    author: o.author,
    role: o.role,
    rating: o.rating,
    text: o.text,
    service: o.relatedService,
  }));
const featuredServices = [
  {
    service: services[0],
    icon: Car,
    title: 'Wycena pojazdu',
    text: 'Wartość rynkowa, szkoda, leasing, spadek wartości.',
  },
  {
    service: services[1],
    icon: Wrench,
    title: 'Ekspertyzy',
    text: 'Powypadkowe, techniczne i celno-skarbowe.',
  },
  {
    service: services[7],
    icon: Scale,
    title: 'Pomoc prawna',
    text: 'Materiały do odwołań, sporów i ubezpieczycieli.',
  },
  {
    service: services[10],
    icon: Gavel,
    title: 'Biegły sądowy',
    text: 'Opinie sądowe, skarbowe i techniczne.',
  },
  {
    service: services[4],
    icon: ShoppingCart,
    title: 'Doradztwo',
    text: 'Zakup, oględziny i weryfikacja dokumentów.',
  },
];
const coverageRows = [
  {
    tone: 'blue',
    title: 'Wielkopolska',
    text: 'Poznań i okolice',
  },
  {
    tone: 'blue',
    title: 'Dolny Śląsk',
    text: 'Wrocław i okolice',
  },
  {
    tone: 'red',
    title: 'Cała Polska',
    text: 'Ponad 60 miast',
  },
];
const serviceProofs = [
  {
    icon: Clock,
    title: 'Szybka odpowiedź',
    text: 'Termin 24-48h',
  },
  {
    icon: ShieldCheck,
    title: 'Doświadczenie',
    text: `Certyfikat ${business.certificate}`,
  },
  {
    icon: MapPin,
    title: 'Zasięg ogólnopolski',
    text: 'Dojazd do Ciebie',
  },
];
---

<BaseLayout
  title="Rzeczoznawca samochodowy – wycena pojazdów"
  description="Certyfikowany rzeczoznawca samochodowy (RS001771). Wyceny pojazdów, ekspertyzy powypadkowe i opinie biegłego w całej Polsce."
  keywords={['rzeczoznawca samochodowy', 'wycena pojazdu', 'biegły sądowy', 'wycena celno-skarbowa', 'ekspertyza pojazdu']}
>
  <!-- HERO -->
  <section class="relative isolate overflow-hidden bg-brand-900 text-white">
    <div class="hero-motion-layer absolute inset-y-0 right-0 z-0 hidden w-[76%] overflow-hidden lg:block" aria-hidden="true">
      <video
        class="hero-car-video absolute inset-0 h-full w-full object-cover opacity-100"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      >
        <source src="/uploads/hero-background-video-v2.mp4" type="video/mp4" media="(min-width: 1024px)" />
      </video>
    </div>
    <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_78%_42%,rgba(116,174,236,0.22),transparent_40%),linear-gradient(105deg,rgba(8,25,41,0.78)_0%,rgba(18,52,90,0.42)_48%,rgba(20,55,92,0.1)_100%)]"></div>
    <div class="absolute inset-0 z-0 bg-[linear-gradient(90deg,rgba(7,21,34,0.9)_0%,rgba(7,21,34,0.56)_45%,rgba(7,21,34,0.02)_100%)]"></div>
    <div class="absolute inset-x-0 bottom-0 z-0 h-px bg-white/10"></div>
    <div class="container relative z-10 mx-auto max-w-7xl overflow-hidden px-4 py-20 lg:py-28">
      <div class="w-full max-w-3xl">
        <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-sky-200">
          Certyfikat {business.certificate}
        </p>
        <h1 class="mb-6 max-w-3xl text-3xl font-bold leading-[1.08] text-white sm:text-4xl md:text-5xl lg:text-6xl">
          Rzeczoznawca Techniki Samochodowej
        </h1>
        <p class="mb-8 w-full max-w-2xl text-base leading-relaxed text-slate-200 sm:text-lg md:text-xl">
          Profesjonalne wyceny pojazdów, ekspertyzy powypadkowe, wyceny celno-skarbowe
          oraz opinie biegłego sądowego i skarbowego. Działam w Wielkopolsce, na Dolnym
          Śląsku oraz w całej Polsce.
        </p>
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a
            href={`tel:${business.contact.phone}`}
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-brand-600 px-6 py-3 font-semibold text-white shadow-xl shadow-brand-950/25 transition hover:bg-brand-500 sm:w-auto"
          >
            <Phone size={18} aria-hidden="true" />
            {business.contact.phoneDisplay}
          </a>
          <a
            href="#kontakt"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white/25 bg-white/5 px-6 py-3 font-semibold text-white backdrop-blur transition hover:bg-white/10 sm:w-auto"
          >
            <MessageCircle size={18} aria-hidden="true" />
            Wyślij zapytanie
          </a>
        </div>
      </div>
    </div>

    {heroReviews.length > 0 && (
      <div class="pointer-events-none absolute inset-x-4 bottom-6 z-20 hidden justify-end lg:flex lg:inset-x-auto lg:bottom-10 lg:right-10">
        <div class="pointer-events-auto w-full max-w-none">
          <HeroReviews client:idle reviews={heroReviews} />
        </div>
      </div>
    )}
  </section>

  <!-- USP STRIPE -->
  <section class="border-y border-slate-200 bg-white">
    <div class="container mx-auto max-w-7xl px-4 py-7">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <div class="flex items-center gap-4">
          <span class="grid h-14 w-14 flex-shrink-0 place-items-center rounded-full border border-slate-200 bg-brand-50 text-brand-700">
            <Award size={28} aria-hidden="true" />
          </span>
          <div>
            <p class="font-semibold text-slate-950">Certyfikat {business.certificate}</p>
            <p class="text-sm text-slate-600">Wpisany do rejestru rzeczoznawców</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <span class="grid h-14 w-14 flex-shrink-0 place-items-center rounded-full border border-slate-200 bg-brand-50 text-brand-700">
            <Clock size={28} aria-hidden="true" />
          </span>
          <div>
            <p class="font-semibold text-slate-950">Termin 24-48h</p>
            <p class="text-sm text-slate-600">Szybkie ekspertyzy bez zbędnego czekania</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <span class="grid h-14 w-14 flex-shrink-0 place-items-center rounded-full border border-slate-200 bg-brand-50 text-brand-700">
            <MapPin size={28} aria-hidden="true" />
          </span>
          <div>
            <p class="font-semibold text-slate-950">Cała Polska</p>
            <p class="text-sm text-slate-600">Wielkopolska, Dolny Śląsk i pozostałe regiony</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- USŁUGI -->
  <section id="uslugi" class="relative overflow-hidden bg-[#041321] py-14 text-white sm:py-16 lg:py-20">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(28,111,183,0.34),transparent_34%),linear-gradient(140deg,rgba(7,28,49,0.98),rgba(2,12,24,1))]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-sky-200/30"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-slate-950/50"></div>
    <div class="container relative z-10 mx-auto max-w-[96rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-8 max-w-3xl text-center lg:mb-10">
        <h2 class="mb-3 text-3xl font-bold text-white md:text-4xl">Oferta usług</h2>
        <p class="text-sm font-medium text-slate-300 md:text-base">Profesjonalnie. Rzetelnie. W całej Polsce.</p>
      </div>

      <div class="mx-auto grid max-w-6xl grid-cols-2 gap-3 border-b border-sky-200/10 pb-8 sm:grid-cols-3 md:gap-5 lg:max-w-none lg:grid-cols-5 lg:pb-10">
        {featuredServices.map(({ service, icon: FeaturedIcon, title, text }) => (
          <a
            href={serviceUrl(service.slug)}
            class="group flex min-h-40 flex-col items-center justify-start rounded-2xl border border-transparent px-3 py-3 text-center transition hover:border-sky-300/25 hover:bg-white/[0.04] last:col-span-2 last:mx-auto last:w-[calc(50%-0.375rem)] sm:last:col-span-1 sm:last:mx-0 sm:last:w-auto lg:min-h-44 lg:px-5 lg:py-4"
          >
            <span class="mb-4 grid h-12 w-12 place-items-center text-slate-200 transition group-hover:text-sky-200 lg:h-14 lg:w-14">
              <FeaturedIcon size={38} strokeWidth={1.55} aria-hidden="true" />
            </span>
            <span class="min-h-[2.6rem] text-sm font-bold leading-tight text-slate-100 lg:text-base">{title}</span>
            <span class="mt-3 h-1 w-9 rounded-full bg-red-600 transition group-hover:w-12 group-hover:bg-sky-300"></span>
            <span class="mt-3 max-w-44 text-xs leading-relaxed text-slate-400 transition group-hover:text-slate-200">
              {text}
            </span>
          </a>
        ))}
      </div>

      <div class="mt-9 grid gap-8 xl:grid-cols-[0.66fr_1.34fr] xl:items-start">
        <div class="mx-auto w-full max-w-xl xl:max-w-none">
          <h3 class="mb-6 text-2xl font-bold tracking-tight text-white md:text-3xl">Działamy w Polsce</h3>
          <ul class="grid gap-4 sm:grid-cols-3 xl:grid-cols-1">
            {coverageRows.map((row) => (
              <li class="flex items-center gap-4 rounded-2xl border border-sky-200/10 bg-white/[0.035] px-4 py-3 xl:border-transparent xl:bg-transparent xl:px-0 xl:py-0">
                <span
                  class:list={[
                    'grid h-10 w-10 shrink-0 place-items-center rounded-full text-lg font-black text-white shadow-lg shadow-black/25 ring-1 ring-white/15',
                    row.tone === 'red' ? 'bg-red-600' : 'bg-sky-500',
                  ]}
                >
                  ✓
                </span>
                <span>
                  <span class="block text-base font-bold leading-tight text-white">{row.title}</span>
                  <span class="block text-sm leading-snug text-slate-400">{row.text}</span>
                </span>
              </li>
            ))}
          </ul>
          <div class="mt-6 rounded-2xl border border-sky-200/10 bg-white/[0.04] p-4 text-sm leading-relaxed text-slate-300">
            <p class="font-semibold text-white">Siedziba: {business.address.city}</p>
            <p class="mt-1">Stała obsługa: Wielkopolska i Dolny Śląsk. Pozostałe województwa są możliwe po ustaleniu zakresu, terminu i dojazdu.</p>
          </div>
        </div>

        <div class="relative mx-auto aspect-[1.064/1] w-full max-w-3xl xl:max-w-[50rem] 2xl:max-w-[54rem]">
          <div class="absolute inset-6 rounded-full bg-sky-500/10 blur-3xl"></div>
          <svg viewBox={`0 0 ${MAP_W} ${MAP_H}`} class="relative z-10 h-full w-full drop-shadow-[0_22px_45px_rgba(0,0,0,0.35)]" role="img" aria-label="Mapa Polski z zaznaczonym zasięgiem rzeczoznawcy">
            <g>
              {renderedVoivodeships.map((v) => {
                const isWielkopolska = v.name === 'wielkopolskie';
                const isDolnySlask = v.name === 'dolnośląskie';
                const isCoreRegion = isWielkopolska || isDolnySlask;
                const tooltipText = isCoreRegion ? 'Stały region obsługi' : 'Do ustalenia';
                const tooltipWidth = isCoreRegion ? 210 : 154;
                return (
                  <g class="group cursor-pointer">
                    <path
                      d={v.path}
                      fill={isCoreRegion ? '#0d62b6' : '#153553'}
                      stroke={isCoreRegion ? '#4ea3ff' : '#285071'}
                      stroke-width={isCoreRegion ? '2.2' : '1.2'}
                      stroke-linejoin="round"
                      opacity={isCoreRegion ? '0.96' : '0.72'}
                      class="transition duration-200 group-hover:fill-[#f5f0dc] group-hover:stroke-white group-hover:opacity-100"
                    >
                      <title>{`${v.name}: ${tooltipText}`}</title>
                    </path>
                    <g
                      class="pointer-events-none opacity-0 transition duration-150 group-hover:opacity-100"
                      transform={`translate(${v.tooltipX} ${v.tooltipY})`}
                    >
                      <rect
                        x={-(tooltipWidth / 2)}
                        y="-32"
                        width={tooltipWidth}
                        height="44"
                        rx="12"
                        fill="#f8f4e8"
                        stroke="#ffffff"
                        stroke-width="2"
                      />
                      <text
                        x="0"
                        y="-8"
                        text-anchor="middle"
                        font-size="24"
                        font-weight="800"
                        fill="#0f2741"
                      >
                        {tooltipText}
                      </text>
                    </g>
                  </g>
                );
              })}
            </g>

            <g>
              {cityMarkers.map((c) => {
                if (c.tier === 'major') {
                  return (
                    <g>
                      <circle cx={c.x} cy={c.y} r="5.5" fill="#f8fbff" opacity="0.95">
                        <title>{c.name}</title>
                      </circle>
                      <text
                        x={c.labelX}
                        y={c.labelY}
                        text-anchor={c.align}
                        font-size="22"
                        font-weight="800"
                        fill="#ffffff"
                        opacity="0.98"
                        paint-order="stroke"
                        stroke="#061729"
                        stroke-width="5"
                        stroke-linejoin="round"
                      >
                        {c.name}
                      </text>
                    </g>
                  );
                }
                return (
                  <g class="map-city-small cursor-pointer">
                    <circle
                      cx={c.x}
                      cy={c.y}
                      r="3.6"
                      fill="#f8fbff"
                      opacity="0.7"
                      class="map-city-small-dot"
                    >
                      <title>{c.name}</title>
                    </circle>
                    <text
                      x={c.labelX}
                      y={c.labelY}
                      text-anchor={c.align}
                      font-size="14"
                      font-weight="700"
                      fill="#d8ecff"
                      paint-order="stroke"
                      stroke="#061729"
                      stroke-width="3.4"
                      stroke-linejoin="round"
                      class="map-city-small-label pointer-events-none"
                    >
                      {c.name}
                    </text>
                  </g>
                );
              })}
            </g>

            <g>
              {brandPins.map((p) => (
                <g transform={`translate(${p.x} ${p.y})`}>
                  {p.primary ? (
                    <>
                      <circle r="24" cx="0" cy="0" fill="#dc2626" opacity="0.55" class="map-hq-ring" />
                      <circle r="24" cx="0" cy="0" fill="#dc2626" opacity="0" class="map-hq-ring-late" />
                      <g class="map-hq-core">
                        <circle r="22" fill="#dc2626" stroke="#ffd9d3" stroke-width="4" />
                        <circle r="7" fill="#ffffff" />
                      </g>
                      <g transform="translate(40 -78)">
                        <rect x="0" y="0" width="252" height="74" rx="14" fill="#f8f4e8" stroke="#dc2626" stroke-width="2.5" />
                        <rect x="0" y="0" width="6" height="74" rx="3" fill="#dc2626" />
                        <text x="22" y="26" font-size="18" font-weight="800" fill="#dc2626" letter-spacing="1.2">SIEDZIBA</text>
                        <text x="22" y="48" font-size="19" font-weight="800" fill="#0f2741">{p.name}</text>
                        <text x="22" y="65" font-size="13" font-weight="600" fill="#475569">k. Ostrowa Wielkopolskiego</text>
                      </g>
                    </>
                  ) : (
                    <>
                      <circle r="34" fill="#1d75d8" opacity="0.18" />
                      <circle r="19" fill="#1d75d8" stroke="#9ed0ff" stroke-width="4" />
                      <circle r="6" fill="#ffffff" />
                      <g transform="translate(-182 28)">
                        <rect x="0" y="0" width="160" height="42" rx="12" fill="#102d49" stroke="#8cc7ff" stroke-width="1.5" opacity="0.92" />
                        <text x="80" y="27" text-anchor="middle" font-size="17" font-weight="800" fill="#dff2ff">{p.name}</text>
                      </g>
                    </>
                  )}
                </g>
              ))}
            </g>
          </svg>
        </div>
      </div>

      <div class="mt-9 grid overflow-hidden rounded-2xl border border-sky-200/10 bg-white/[0.04] shadow-2xl shadow-black/15 md:grid-cols-3 lg:mt-10">
        {serviceProofs.map(({ icon: ProofIcon, title, text }) => (
          <div class="flex min-h-20 items-center gap-3 border-b border-sky-200/10 px-5 py-4 md:border-b-0 md:border-r md:last:border-r-0 lg:px-7">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full border border-sky-200/25 bg-sky-300/10 text-sky-100">
              <ProofIcon size={22} strokeWidth={1.9} aria-hidden="true" />
            </span>
            <span>
              <span class="block text-sm font-bold leading-tight text-white">{title}</span>
              <span class="block text-xs leading-snug text-slate-400">{text}</span>
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- KONTAKT -->
  <section id="kontakt" class="border-t border-slate-200 bg-white py-16 lg:py-20">
    <div class="container mx-auto max-w-7xl px-4">
      <div class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
        <div>
          <h2 class="mb-4 text-3xl font-bold text-slate-950 md:text-4xl">Skontaktuj się</h2>
          <div class="mb-5 h-1 w-12 rounded-full bg-brand-600"></div>
          <p class="max-w-md leading-relaxed text-slate-600">
            Opisz krótko swoją sprawę – odezwę się w ciągu 24h, zazwyczaj znacznie szybciej.
          </p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-xl shadow-slate-950/[0.04] md:p-8">
          <ContactForm client:idle turnstileSiteKey={turnstileSiteKey} />
        </div>
      </div>
      {turnstileSiteKey && (
        <script
          is:inline
          src="https://challenges.cloudflare.com/turnstile/v0/api.js"
          async
          defer
        />
      )}
    </div>
  </section>
</BaseLayout>
