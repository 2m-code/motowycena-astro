---
import BaseLayout from '@layouts/BaseLayout.astro';
import { business, services, serviceUrl } from '@data/business';
import { Phone, MessageCircle, Award, Clock, MapPin } from 'lucide-react';
import ContactForm from '@components/forms/ContactForm.tsx';

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<BaseLayout
  title="Rzeczoznawca samochodowy – wycena pojazdów"
  description="Certyfikowany rzeczoznawca samochodowy (RS001771). Wyceny pojazdów, ekspertyzy powypadkowe i opinie biegłego w całej Polsce."
  keywords={['rzeczoznawca samochodowy', 'wycena pojazdu', 'biegły sądowy', 'wycena celno-skarbowa', 'ekspertyza pojazdu']}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-brand-900 text-white">
    <img
      src="/uploads/black-bmw-m3-coupe-car.png"
      alt="Czarny samochód sportowy użyty na stronie Motowycena"
      loading="eager"
      decoding="async"
      class="absolute bottom-0 right-0 hidden w-[58rem] max-w-[68%] opacity-35 lg:block"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-brand-900 via-brand-800/95 to-brand-600/80"></div>
    <div class="container relative mx-auto px-4 max-w-7xl py-20 lg:py-28">
      <div class="max-w-3xl">
        <p class="text-brand-100 text-sm font-semibold uppercase tracking-wider mb-3">
          Certyfikat {business.certificate}
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Rzeczoznawca Techniki Samochodowej
        </h1>
        <p class="text-lg md:text-xl text-brand-50 mb-8 leading-relaxed">
          Profesjonalne wyceny pojazdów, ekspertyzy powypadkowe, wyceny celno-skarbowe
          oraz opinie biegłego sądowego i skarbowego. Działam w Wielkopolsce, na Dolnym
          Śląsku oraz w całej Polsce.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={`tel:${business.contact.phone}`}
            class="inline-flex items-center gap-2 bg-white text-brand-700 hover:bg-brand-50 font-semibold px-6 py-3 rounded-lg transition"
          >
            <Phone size={18} aria-hidden="true" />
            {business.contact.phoneDisplay}
          </a>
          <a
            href="#kontakt"
            class="inline-flex items-center gap-2 bg-brand-600/40 hover:bg-brand-600/60 backdrop-blur text-white border border-white/30 font-semibold px-6 py-3 rounded-lg transition"
          >
            <MessageCircle size={18} aria-hidden="true" />
            Wyślij zapytanie
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- USP STRIPE -->
  <section class="bg-gray-50 border-y border-gray-200">
    <div class="container mx-auto px-4 max-w-7xl py-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="flex items-center gap-3">
          <Award className="text-brand-600 flex-shrink-0" size={32} aria-hidden="true" />
          <div>
            <p class="font-semibold">Certyfikat {business.certificate}</p>
            <p class="text-sm text-gray-600">Wpisany do rejestru rzeczoznawców</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <Clock className="text-brand-600 flex-shrink-0" size={32} aria-hidden="true" />
          <div>
            <p class="font-semibold">Termin 24-48h</p>
            <p class="text-sm text-gray-600">Szybkie ekspertyzy bez zbędnego czekania</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <MapPin className="text-brand-600 flex-shrink-0" size={32} aria-hidden="true" />
          <div>
            <p class="font-semibold">Cała Polska</p>
            <p class="text-sm text-gray-600">Wielkopolska, Dolny Śląsk i pozostałe regiony</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- USŁUGI -->
  <section id="uslugi" class="py-16 lg:py-20">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Oferta usług</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Pełny zakres usług rzeczoznawcy techniki samochodowej – od wyceny rynkowej
          po opinie biegłego sądowego.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a
            href={serviceUrl(service.slug)}
            class="block bg-white border border-gray-200 hover:border-brand-500 rounded-xl p-6 transition shadow-sm hover:shadow-md group"
          >
            <h3 class="font-semibold text-lg mb-2 group-hover:text-brand-700 transition">
              {service.name}
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">
              {service.shortDesc}
            </p>
            <p class="text-sm text-brand-700 font-semibold">Czytaj więcej →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- KONTAKT -->
  <section id="kontakt" class="bg-gray-50 py-16 lg:py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Skontaktuj się</h2>
        <p class="text-gray-600">
          Opisz krótko swoją sprawę – odezwę się w ciągu 24h, zazwyczaj znacznie szybciej.
        </p>
      </div>
      <div class="bg-white rounded-2xl shadow-lg p-6 md:p-10">
        <ContactForm client:idle turnstileSiteKey={turnstileSiteKey} />
      </div>
      {turnstileSiteKey && (
        <script
          src="https://challenges.cloudflare.com/turnstile/v0/api.js"
          async
          defer
        />
      )}
    </div>
  </section>
</BaseLayout>
