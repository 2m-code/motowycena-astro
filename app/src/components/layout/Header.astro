---
import { business, services, serviceUrl } from '@data/business';
import { Phone } from 'lucide-react';
import MobileMenu from './MobileMenu.tsx';

// Mapujemy services do plain objektów (readonly tuple z `as const` w business.ts
// nie przechodzi czysto przez serializację props - bierzemy tylko slug+name).
const mobileMenuServices = services.map((s) => ({ slug: s.slug, name: s.name }));
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-md border-b border-gray-200">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-bold text-xl text-brand-700 hover:text-brand-900 transition">
        <span class="sr-only">{business.name} – strona główna</span>
        <span aria-hidden="true">🚗</span>
        <span>{business.name}</span>
      </a>

      <!-- Desktop menu -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Menu główne">
        <a href="/" class="px-3 py-2 text-sm hover:text-brand-700 transition">Strona główna</a>
        <div class="relative group">
          <button class="px-3 py-2 text-sm hover:text-brand-700 transition" aria-haspopup="true">
            Usługi ▾
          </button>
          <div class="absolute top-full right-0 mt-1 w-80 bg-white shadow-xl rounded-lg p-2 invisible group-hover:visible opacity-0 group-hover:opacity-100 transition">
            {services.map((s) => (
              <a href={serviceUrl(s.slug)} class="block px-4 py-2 text-sm hover:bg-gray-50 rounded">
                {s.name}
              </a>
            ))}
          </div>
        </div>
        <a href="/pomoc-prawna/" class="px-3 py-2 text-sm hover:text-brand-700 transition">Pomoc prawna</a>
        <a href="/realizacje/" class="px-3 py-2 text-sm hover:text-brand-700 transition">Realizacje</a>
        <a href="/biegly-sadowy/" class="px-3 py-2 text-sm hover:text-brand-700 transition">Biegły sądowy</a>
        <a href="/biegly-skarbowy/" class="px-3 py-2 text-sm hover:text-brand-700 transition">Biegły skarbowy</a>
        <a href="/kontakt/" class="px-3 py-2 text-sm hover:text-brand-700 transition">Kontakt</a>
      </nav>

      <!-- CTA Phone -->
      <a
        href={`tel:${business.contact.phone}`}
        class="hidden md:inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition"
        aria-label={`Zadzwoń: ${business.contact.phoneDisplay}`}
      >
        <Phone size={16} aria-hidden="true" />
        {business.contact.phoneDisplay}
      </a>

      <!-- Mobile menu - React island, hydratacja w idle (po LCP). -->
      <MobileMenu
        client:idle
        services={mobileMenuServices}
        phone={business.contact.phone}
        phoneDisplay={business.contact.phoneDisplay}
        whatsapp={business.contact.whatsapp}
      />

      <!-- Fallback no-JS: pokazujemy przycisk linkujący do #footer-nav (działa zawsze). -->
      <noscript>
        <a
          href="#footer-nav"
          class="lg:hidden p-2 -mr-2 text-gray-900"
          aria-label="Przejdź do menu w stopce"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </a>
      </noscript>
    </div>
  </div>
</header>
