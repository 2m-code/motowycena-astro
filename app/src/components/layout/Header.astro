---
import { business, services, serviceUrl } from '@data/business';
import { Phone } from 'lucide-react';
import MobileMenu from './MobileMenu.tsx';

// Mapujemy services do plain objektów (readonly tuple z `as const` w business.ts
// nie przechodzi czysto przez serializację props - bierzemy tylko slug+name).
const mobileMenuServices = services.map((s) => ({ slug: s.slug, name: s.name }));
---

<header class="sticky top-0 z-40 border-b border-slate-200/80 bg-white/90 shadow-[0_1px_0_rgba(15,23,42,0.03)] backdrop-blur-xl">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="flex h-16 items-center justify-between lg:h-[4.5rem]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 font-bold text-xl text-brand-700 transition hover:text-brand-900">
        <span class="sr-only">{business.name} – strona główna</span>
        <img src="/favicon.svg" alt="" width="32" height="32" class="block rounded-lg" style="width: 32px; height: 32px;" loading="eager" decoding="async" />
        <span aria-hidden="true" class="text-lg font-extrabold tracking-normal text-brand-700">{business.name}</span>
      </a>

      <!-- Desktop menu -->
      <nav class="hidden items-center gap-1 lg:flex" aria-label="Menu główne">
        <a href="/" class="rounded-full px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-brand-700">Strona główna</a>
        <div class="relative group">
          <button class="rounded-full px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-brand-700" aria-haspopup="true">
            Usługi ▾
          </button>
          <div class="invisible absolute right-0 top-full mt-3 w-80 rounded-2xl border border-slate-200 bg-white p-2 opacity-0 shadow-2xl shadow-slate-950/10 transition group-hover:visible group-hover:opacity-100">
            {services.map((s) => (
              <a href={serviceUrl(s.slug)} class="block rounded-xl px-4 py-2.5 text-sm text-slate-700 transition hover:bg-brand-50 hover:text-brand-700">
                {s.name}
              </a>
            ))}
          </div>
        </div>
        <a href="/pomoc-prawna/" class="rounded-full px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-brand-700">Pomoc prawna</a>
        <a href="/realizacje/" class="rounded-full px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-brand-700">Realizacje</a>
        <a href="/biegly-sadowy/" class="rounded-full px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-brand-700">Biegły sądowy</a>
        <a href="/biegly-skarbowy/" class="rounded-full px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-brand-700">Biegły skarbowy</a>
        <a href="/kontakt/" class="rounded-full px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-brand-700">Kontakt</a>
      </nav>

      <!-- CTA Phone -->
      <a
        href={`tel:${business.contact.phone}`}
        class="hidden items-center gap-2 rounded-xl bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-brand-900/15 transition hover:bg-brand-800 md:inline-flex"
        aria-label={`Zadzwoń: ${business.contact.phoneDisplay}`}
      >
        <Phone size={16} aria-hidden="true" />
        {business.contact.phoneDisplay}
      </a>

      <!-- Mobile menu - React island, hydratacja w idle (po LCP). -->
      <MobileMenu
        client:idle
        services={mobileMenuServices}
        phone={business.contact.phone}
        phoneDisplay={business.contact.phoneDisplay}
        whatsapp={business.contact.whatsapp}
      />

      <!-- Fallback no-JS: pokazujemy przycisk linkujący do #footer-nav (działa zawsze). -->
      <noscript>
        <a
          href="#footer-nav"
          class="lg:hidden p-2 -mr-2 text-gray-900"
          aria-label="Przejdź do menu w stopce"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </a>
      </noscript>
    </div>
  </div>
</header>
