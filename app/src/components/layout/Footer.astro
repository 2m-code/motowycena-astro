---
import { business, services, serviceUrl } from '@data/business';
import { Phone, Mail, MapPin, MessageCircle } from 'lucide-react';
---

<footer id="footer-nav" class="mt-0 bg-brand-900 text-slate-300">
  <div class="container mx-auto max-w-7xl px-4 py-12">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      <!-- Firma -->
      <div>
        <h3 class="mb-4 text-lg font-bold text-white">{business.name}</h3>
        <p class="mb-2 text-sm leading-relaxed">{business.legalName}</p>
        <p class="text-xs text-slate-400">Certyfikat: {business.certificate}</p>
      </div>

      <!-- Usługi -->
      <div>
        <h3 class="mb-4 font-semibold text-white">Usługi</h3>
        <ul class="space-y-2 text-sm">
          {services.slice(0, 6).map((s) => (
            <li>
              <a href={serviceUrl(s.slug)} class="transition hover:text-white">{s.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Linki -->
      <div>
        <h3 class="mb-4 font-semibold text-white">Informacje</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/realizacje/" class="transition hover:text-white">Realizacje</a></li>
          <li><a href="/biegly-sadowy/" class="transition hover:text-white">Biegły sądowy</a></li>
          <li><a href="/biegly-skarbowy/" class="transition hover:text-white">Biegły skarbowy</a></li>
          <li><a href="/pomoc-prawna/" class="transition hover:text-white">Pomoc prawna</a></li>
          <li><a href="/rzeczoznawca-ostrow-wielkopolski/" class="transition hover:text-white">Ostrów Wielkopolski</a></li>
          <li><a href="/kontakt/" class="transition hover:text-white">Kontakt</a></li>
          <li><a href="/polityka-prywatnosci/" class="transition hover:text-white">Polityka prywatności</a></li>
        </ul>
      </div>

      <!-- Kontakt -->
      <div>
        <h3 class="mb-4 font-semibold text-white">Dane kontaktowe</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <Phone size={16} className="mt-0.5 flex-shrink-0 text-slate-400" aria-hidden="true" />
            <a href={`tel:${business.contact.phone}`} class="transition hover:text-white">
              {business.contact.phoneDisplay}
            </a>
          </li>
          <li class="flex items-start gap-2">
            <MessageCircle size={16} className="mt-0.5 flex-shrink-0 text-slate-400" aria-hidden="true" />
            <a href={`https://wa.me/${business.contact.whatsapp.replace(/[^0-9]/g, '')}`} class="transition hover:text-white">
              WhatsApp: {business.contact.phoneDisplay}
            </a>
          </li>
          <li class="flex items-start gap-2">
            <Mail size={16} className="mt-0.5 flex-shrink-0 text-slate-400" aria-hidden="true" />
            <a href={`mailto:${business.contact.email}`} class="break-all transition hover:text-white">
              {business.contact.email}
            </a>
          </li>
          <li class="flex items-start gap-2">
            <MapPin size={16} className="mt-0.5 flex-shrink-0 text-slate-400" aria-hidden="true" />
            <address class="not-italic">
              {business.address.street}<br />
              {business.address.postalCode} {business.address.city}
            </address>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-white/10 pt-8">
      <h3 class="mb-3 font-semibold text-white">Obszar działania</h3>
      <div class="grid gap-3 text-sm leading-relaxed text-slate-400 md:grid-cols-3">
        <p><strong class="text-slate-300">Wielkopolska:</strong> {business.serviceAreas.wielkopolska}.</p>
        <p><strong class="text-slate-300">Dolnośląskie:</strong> {business.serviceAreas.dolnoslaskie}.</p>
        <p><strong class="text-slate-300">Cała Polska:</strong> {business.serviceAreas.nationwide}.</p>
      </div>
    </div>

    <div class="mt-8 flex flex-col justify-between gap-4 border-t border-white/10 pt-6 text-xs text-slate-500 md:flex-row">
      <p>© {new Date().getFullYear()} {business.legalName}. Wszelkie prawa zastrzeżone.</p>
      <p>
        Powered by {business.name}
      </p>
    </div>
  </div>
</footer>
