# Skopiuj do .env i uzupełnij. Pliku .env NIE COMMITUJ do gita.
# Na produkcji te zmienne ustawiasz w Cloudflare Pages → Settings → Environment variables.

# ===== Wysyłka formularza =====
# Resend.com – wysyłka emaila z formularza (3000 emaili/mc darmowo).
# Załóż konto: https://resend.com → API Keys → Create API key
RESEND_API_KEY=

# Email na który mają przychodzić zapytania
CONTACT_EMAIL=biuro@motowycena.pl

# Adres "From:" (musi być z weryfikowanej domeny w Resend)
MAIL_FROM=Formularz <noreply@motowycena.pl>

# ===== Anti-spam =====
# Cloudflare Turnstile – darmowy reCAPTCHA-killer.
# https://dash.cloudflare.com → Turnstile → Add Site → wybierz "Managed"
# Site key jest publiczny (renderuje widget), Secret key tajny (weryfikuje serwer).
TURNSTILE_SECRET_KEY=
PUBLIC_TURNSTILE_SITE_KEY=

# ===== Analytics =====
# Cloudflare Web Analytics – statystyki bez cookies, RODO-friendly, darmowe.
# https://dash.cloudflare.com → Analytics → Web Analytics → Add a site
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=
