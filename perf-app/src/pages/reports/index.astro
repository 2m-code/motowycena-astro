---
import Layout from '@/layouts/Layout.astro';
import { listReports } from '@lib/perf/storage';

export const prerender = false;

const reports = await listReports(100);

const verdictColor = (v: string): string => {
  if (v === 'good') return 'bg-green-100 text-green-800';
  if (v === 'needs-work') return 'bg-amber-100 text-amber-800';
  return 'bg-red-100 text-red-800';
};

const verdictLabel = (v: string): string => {
  if (v === 'good') return 'GOOD';
  if (v === 'needs-work') return 'NEEDS WORK';
  return 'POOR';
};
---

<Layout title="Historia audytów – Perf Audit">
  <section class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold">📊 Historia audytów</h1>
    <a
      href="/"
      class="text-sm bg-brand-600 hover:bg-brand-700 text-white px-4 py-2 rounded-lg"
    >
      + Nowy audit
    </a>
  </section>

  {reports.length === 0 ? (
    <div class="bg-white border border-gray-200 rounded-xl p-10 text-center text-gray-500">
      <p class="mb-2 text-lg">Brak zapisanych raportów</p>
      <p class="text-sm">Zrób pierwszy audit żeby pojawiła się tu historia.</p>
    </div>
  ) : (
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-3">URL</th>
            <th class="px-4 py-3">Verdict</th>
            <th class="px-4 py-3 text-right">LCP p75</th>
            <th class="px-4 py-3 text-right">CLS p75</th>
            <th class="px-4 py-3">Data</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {reports.map((r) => (
            <tr class="border-t border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3 max-w-md truncate">
                <a
                  href={`/reports/${encodeURIComponent(r.host)}/${r.id}/`}
                  class="text-brand-700 hover:underline font-mono text-xs"
                >
                  {r.url}
                </a>
              </td>
              <td class="px-4 py-3">
                <span class={`inline-block px-2 py-0.5 rounded text-xs font-semibold ${verdictColor(r.verdict)}`}>
                  {verdictLabel(r.verdict)}
                </span>
              </td>
              <td class="px-4 py-3 text-right font-mono">{Math.round(r.lcpP75)} ms</td>
              <td class="px-4 py-3 text-right font-mono">{r.clsP75.toFixed(3)}</td>
              <td class="px-4 py-3 text-gray-500 text-xs">
                {new Date(r.startedAt).toLocaleString('pl-PL')}
              </td>
              <td class="px-4 py-3">
                <a
                  href={`/reports/${encodeURIComponent(r.host)}/${r.id}/`}
                  class="text-brand-700 hover:underline text-xs"
                >
                  Otwórz →
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</Layout>
